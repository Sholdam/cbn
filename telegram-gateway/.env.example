# Obtenha API_ID e API_HASH em my.telegram.org > API development tools.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Gerada uma única vez pelo comando: npm run auth
# Trate esta string como uma senha. Nunca envie em chat, planilha ou print.
TELEGRAM_SESSION=

# Conta usada somente no primeiro login.
TELEGRAM_PHONE=+55DDDNUMERO

# Opcional: senha de verificação em duas etapas da conta Telegram.
TELEGRAM_2FA_PASSWORD=

# Usuário do bot operacional, com ou sem @.
TARGET_USERNAME=

# Mensagem segura para o teste. Use um comando que apenas abra o menu.
TEST_MESSAGE=menu

# Tempo máximo para aguardar resposta do bot.
RESPONSE_TIMEOUT_MS=30000
